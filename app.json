{
  "expo": {
    "name": "Mana Vault",
    "slug": "mana-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "manavault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.codex.manavault",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Mana Vault to scan Magic: The Gathering cards."
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.codex.manavault",
      "adaptiveIcon": {
        "backgroundColor": "#f4efe5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Mana Vault to scan Magic cards with the camera."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f3eee3",
          "dark": {
            "backgroundColor": "#11140f"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "097bc76c-dc83-4172-a923-d0d76e783a2f"
      }
    }
  }
}
